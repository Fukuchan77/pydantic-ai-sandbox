# =============================================================================
# pydantic-ai-sandbox — environment variable contract
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in secrets locally. `.env` is gitignored (Req 9.6 /
# T2.1). Defaults shown here are the canonical production-shaped values; comment
# any line out to fall back to the Settings-defined default. NEVER put real
# credentials in this file — secret-bearing variables are intentionally empty.
# =============================================================================

# ---- Runtime mode -----------------------------------------------------------
# Required. development | staging | production
APP_ENV=development
# Required. Standard logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ---- LLM router -------------------------------------------------------------
# Required. Selects the active backend or activates the FallbackModel chain.
# Allowed values: ollama | watsonx | anthropic | bedrock | fallback
LLM_PROVIDER=ollama

# ---- Ollama (local) ---------------------------------------------------------
# Required when LLM_PROVIDER=ollama (or when ollama appears in FALLBACK_ORDER).
OLLAMA_BASE_URL=http://localhost:11434/v1
# Required when LLM_PROVIDER=ollama. Pin an explicit tag in production
# (never `:latest`, per CLAUDE.md model-ID hygiene).
OLLAMA_MODEL_NAME=
# Optional. Only set for Ollama Cloud; leave empty for local daemons.
OLLAMA_API_KEY=

# ---- watsonx.ai (stub in MVP, full impl in 002-multi-provider) --------------
# Optional in MVP. All four are required once the watsonx provider lands.
WATSONX_API_KEY=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=
# Pin via env; see CLAUDE.md for naming drift between watsonx releases.
WATSONX_MODEL_ID=
# Optional. Transport selector for the future provider: sdk | litellm.
WATSONX_TRANSPORT=sdk

# ---- Anthropic direct (stub in MVP) ----------------------------------------
# Optional in MVP. Required once the Anthropic provider is enabled.
ANTHROPIC_API_KEY=
# Pin via env. Examples (do not commit literals into src/):
# claude-sonnet-4-6 / claude-haiku-4-5 / claude-opus-4-7
ANTHROPIC_MODEL=

# ---- AWS Bedrock (stub in MVP) ---------------------------------------------
# Optional in MVP. Required once the Bedrock provider is enabled. Bedrock
# on-demand Sonnet 4.6 mandates a Cross-Region Inference Profile prefix
# (us. / eu. / jp. / global.) — base IDs raise ValidationException.
BEDROCK_MODEL_ID=
AWS_REGION=us-east-1
# Authentication is one of AWS_PROFILE / IAM Role / AWS_BEARER_TOKEN_BEDROCK.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BEARER_TOKEN_BEDROCK=

# ---- Fallback chain ---------------------------------------------------------
# Required when LLM_PROVIDER=fallback. Comma-separated, ordered, no spaces.
# Empty string and unknown-provider-only configurations fail-fast at startup
# (Req 4.5 / Plan §2.4).
FALLBACK_ORDER=ollama

# ---- Logfire / observability -----------------------------------------------
# Optional. Empty = `send_to_logfire="if-token-present"` short-circuits and
# instrumentation runs locally only (Req 5.2).
LOGFIRE_TOKEN=
# Optional. Default false. Set to `true` only in trusted environments to allow
# prompt / tool_input / tool_output payloads through scrubbing (Req 5.4).
LOG_SENSITIVE_PAYLOADS=false

# ---- Test lanes -------------------------------------------------------------
# Optional. Set to 1 to opt into the live-Ollama integration suite
# (`mise run test:integration`); otherwise that lane is skipped (Req 6.2).
RUN_INTEGRATION_OLLAMA=0
